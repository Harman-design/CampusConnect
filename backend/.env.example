# ==============================
# SERVER
# ==============================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ==============================
# MONGODB ATLAS
# ==============================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/campusconnect?retryWrites=true&w=majority

# ==============================
# JWT AUTH
# ==============================
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==============================
# PASSWORD RESET TOKENS
# ==============================
RESET_TOKEN_EXPIRES_MIN=30

# ==============================
# COOKIES
# ==============================
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ==============================
# EMAIL (Nodemailer - for forgot password)
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="CampusConnect <no-reply@campusconnect.edu>"

# ==============================
# FIREBASE STORAGE (Admin SDK)
# ==============================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# ==============================
# GOOGLE GEMINI API (used in Phase 5)
# ==============================
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ==============================
# AI ASSISTANT RATE LIMITING
# ==============================
AI_RATE_LIMIT_WINDOW_MIN=15
AI_RATE_LIMIT_MAX=30

# ==============================
# RATE LIMITING
# ==============================
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=20
