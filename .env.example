# ==========================================
# CAMPUSCONNECT SYSTEM ENVIRONMENT REFERENCE
# ==========================================

# SERVER CONFIGURATIONS
NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-frontend-vercel-domain.vercel.app

# MONGODB DATABASE CONNECTION
# For local Docker: mongodb://db:27017/campusconnect
# For cloud atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017/campusconnect

# CRYPTOGRAPHIC AUTHENTICATION SECRETS (JWT)
# Tip: Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_access_signature_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_signature_secret_key_here
JWT_REFRESH_EXPIRES_IN=7d

# ACCOUNT PASSWORD RESTORE PARAMETERS
RESET_TOKEN_EXPIRES_MIN=30

# SECURITY CLIENT COOKIE SETTINGS
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# SMTP EMAIL CLIENT (e.g., Google SMTP or Mailtrap)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=account-name@gmail.com
SMTP_PASS=your-gmail-application-passcode
SMTP_FROM="SRM CampusConnect Registrar <no-reply@campusconnect.edu>"

# FIREBASE CLOUD STORAGE (Credentials from Firebase Console Service Account SDK)
FIREBASE_PROJECT_ID=srm-campusconnect-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=srm-campusconnect-project-id.appspot.com

# GOOGLE GEMINI AI KEY (AI Studio developer deck)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
GEMINI_MODEL=gemini-3.5-flash

# API PROTECTION RATE LIMITS
AI_RATE_LIMIT_WINDOW_MIN=15
AI_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=20

# RAZORPAY PAYMENT MODULE INTEGRATION
RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=YourRazorpaySecretHere
RAZORPAY_WEBHOOK_SECRET=YourRazorpayWebhookSecretHere
